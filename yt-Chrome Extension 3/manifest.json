{
  "manifest_version": 3,
  "name": "YouTube Custom Timestamps",
  "version": "1.4.1",
  "description": "Create and manage custom timestamps for YouTube videos.",
  "permissions": ["storage", "tabs","unlimitedStorage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["contentScript.js"],
      "css": ["overlay.css"]
    }
  ]
}